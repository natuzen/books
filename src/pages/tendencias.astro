---
import BaseLayout from '../layouts/BaseLayout.astro';
import estrenos from '../../data/estrenos-peliculas.json';
import novedades from '../../data/novedades-libros.json';
---

<BaseLayout
  title="Tendencias"
  description="Próximos estrenos de adaptaciones románticas, novedades editoriales y los libros más votados de la semana."
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="font-playfair text-3xl font-bold text-epoca-marron mb-2">Tendencias</h1>
    <p class="text-epoca-marron-medio mb-10">Lo más leído, lo más esperado y las nuevas voces del romance literario.</p>

    <!-- ============ SECCIÓN 1: Rankings Dinámicos Semanales ============ -->
    <section class="mb-14">
      <div class="flex items-center gap-3 mb-6 border-b-2 border-epoca-violeta-claro pb-3">
        <span class="text-2xl">📊</span>
        <div>
          <h2 class="font-playfair text-2xl text-epoca-marron font-bold">Rankings Dinámicos Semanales</h2>
          <p class="text-sm text-epoca-marron-medio">Los libros más votados por la comunidad esta semana</p>
        </div>
      </div>
      <div class="card-epoca p-6 text-center">
        <p class="text-epoca-marron-medio mb-4">Participa votando por tus favoritos en nuestra sección de Rankings.</p>
        <a href="/rankings" class="btn-primary inline-block">
          🏆 Ver Rankings y Votar
        </a>
      </div>

      <!-- Novedades editoriales -->
      <div class="mt-8">
        <h3 class="font-playfair text-xl text-epoca-marron mb-4">📚 Novedades Editoriales</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {novedades.map(n => (
            <div class="card-epoca">
              <h4 class="font-playfair font-semibold text-epoca-marron">{n.titulo}</h4>
              <p class="text-xs text-epoca-marron-medio mt-0.5">{n.autor} · {n.editorial} · {n.fecha_publicacion}</p>
              <p class="text-sm text-epoca-marron-medio mt-2 leading-relaxed">{n.sinopsis}</p>
              <span class="text-xs bg-epoca-verde-claro text-epoca-marron px-2 py-0.5 rounded-full mt-2 inline-block">{n.genero}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SECCIÓN 2: Calendario Audiovisual ============ -->
    <section>
      <div class="flex items-center gap-3 mb-6 border-b-2 border-epoca-rosa-claro pb-3">
        <span class="text-2xl">🎬</span>
        <div>
          <h2 class="font-playfair text-2xl text-epoca-marron font-bold">Calendario Audiovisual</h2>
          <p class="text-sm text-epoca-marron-medio">Próximas adaptaciones de libros románticos al cine y series</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {estrenos.map(e => (
          <div class="card-epoca">
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <h3 class="font-playfair font-semibold text-epoca-marron">{e.titulo}</h3>
                <p class="text-xs text-epoca-marron-medio mt-0.5">{e.tipo} · {e.plataforma} · {e.fecha_estreno}</p>
                <p class="text-sm text-epoca-marron-medio mt-2 leading-relaxed">{e.sinopsis}</p>
              </div>
              <span class="shrink-0 text-xs bg-epoca-rosa text-white px-2 py-1 rounded-full">{e.genero}</span>
            </div>
            {e.adaptacion_de && (
              <p class="text-xs text-epoca-violeta mt-3 pt-2 border-t border-epoca-violeta-claro">
                📖 Basada en: <em class="font-medium">{e.adaptacion_de}</em>
              </p>
            )}
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
