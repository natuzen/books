---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuizApp from '../components/QuizApp';
import preguntas from '../../data/quiz-preguntas.json';
import libros from '../../data/libros-curados.json';
---

<BaseLayout
  title="Quiz Literario"
  description="Descubre qué tipo de lectora romántica eres con nuestro quiz literario personalizado."
>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-8">
      <h1 class="font-playfair text-3xl font-bold text-epoca-marron mb-2">Quiz Literario</h1>
      <p class="text-epoca-marron-medio">Descubre qué tipo de lectora romántica eres y recibe recomendaciones personalizadas</p>
    </div>
    <QuizApp preguntas={preguntas} libros={libros} client:load />
  </div>
</BaseLayout>
