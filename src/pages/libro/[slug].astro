---
import BaseLayout from '../../layouts/BaseLayout.astro';
import libros from '../../../data/libros-curados.json';

export function getStaticPaths() {
  return libros.map(libro => ({
    params: { slug: libro.slug },
    props: { libro },
  }));
}

interface LibroType {
  id: number;
  titulo: string;
  autor: string;
  anio: number;
  slug: string;
  sinopsis: string;
  tropos: string[];
  intensidad: number;
  categoria: string;
  isbn: string;
  paginas: number;
  editorial: string;
  portada?: string;
}

const { libro } = Astro.props as { libro: LibroType };
const hearts = '♥'.repeat(libro.intensidad) + '♡'.repeat(5 - libro.intensidad);
---

<BaseLayout
  title={libro.titulo}
  description={libro.sinopsis}
  ogImage={libro.portada}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="md:w-64 shrink-0">
        <div class="aspect-[2/3] bg-epoca-violeta-claro rounded-xl overflow-hidden shadow-lg">
          {libro.portada ? (
            <img src={libro.portada} alt={`Portada de ${libro.titulo}`} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-6xl">📚</div>
          )}
        </div>
      </div>
      <div class="flex-1">
        <h1 class="font-playfair text-3xl font-bold text-epoca-marron mb-2">{libro.titulo}</h1>
        <p class="text-epoca-marron-medio text-lg mb-1">{libro.autor}</p>
        <p class="text-epoca-marron-medio text-sm mb-3">{libro.editorial}, {libro.anio} · {libro.paginas} páginas</p>
        <p class="text-epoca-rosa text-xl mb-4" title={`Intensidad romántica: ${libro.intensidad}/5`}>{hearts}</p>
        
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-xs bg-epoca-verde-claro text-epoca-marron px-2 py-1 rounded-full">{libro.categoria}</span>
          {libro.tropos.map(t => (
            <span class="text-xs bg-epoca-violeta-claro text-epoca-marron px-2 py-1 rounded-full">{t}</span>
          ))}
        </div>

        <p class="text-epoca-marron-medio leading-relaxed mb-6">{libro.sinopsis}</p>

        <a
          href={`https://openlibrary.org/isbn/${libro.isbn}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-block"
        >
          Ver en Open Library
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
