---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage = '/og-default.jpg', canonicalUrl } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Queridos Lectores</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={`${title} | Queridos Lectores`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Queridos Lectores",
      "url": "https://queridoslectores.com",
      "description": "Tu guía de romance literario y novelas románticas",
      "inLanguage": "es"
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      // Cover fallback: Open Library → Google Books → placeholder emoji
      document.addEventListener('error', (e) => {
        const img = e.target as HTMLImageElement;
        if (img.tagName !== 'IMG' || !img.dataset.isbn || img.dataset.fallbackDone) return;
        img.dataset.fallbackDone = 'true';
        const isbn = img.dataset.isbn;
        fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${encodeURIComponent(isbn)}&maxResults=1`)
          .then(r => r.json())
          .then((data: { items?: Array<{ volumeInfo?: { imageLinks?: { thumbnail?: string } } }> }) => {
            const thumbnail = data.items?.[0]?.volumeInfo?.imageLinks?.thumbnail;
            if (thumbnail) {
              img.src = thumbnail.replace('http://', 'https://');
            } else {
              showCoverPlaceholder(img);
            }
          })
          .catch(() => showCoverPlaceholder(img));
      }, true);

      function showCoverPlaceholder(img: HTMLImageElement) {
        const container = img.parentElement;
        if (container) {
          const div = document.createElement('div');
          div.className = 'w-full h-full flex items-center justify-center';
          const span = document.createElement('span');
          span.className = 'text-4xl';
          span.textContent = '📚';
          div.appendChild(span);
          container.replaceChildren(div);
        }
      }
    </script>
  </body>
</html>
