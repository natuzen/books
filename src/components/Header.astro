---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/buscar', label: 'Buscar' },
  { href: '/quiz', label: 'Quiz' },
  { href: '/recomiendame', label: 'Recomiéndame' },
  { href: '/generador-citas', label: 'Citas' },
  { href: '/rankings', label: 'Rankings' },
  { href: '/tendencias', label: 'Tendencias' },
  { href: '/listas', label: 'Listas' },
  { href: '/mapa', label: 'Mapa' },
];
---

<header class="bg-white border-b border-epoca-violeta-claro sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo.svg" alt="Queridos Lectores" class="h-10" />
      </a>
      
      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map(item => (
          <a href={item.href} class="px-3 py-1.5 text-sm font-medium text-epoca-marron-medio hover:text-epoca-marron hover:bg-epoca-crema rounded-lg transition-colors font-inter">
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button id="menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-epoca-crema" aria-label="Abrir menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden mt-3 pb-3 border-t border-epoca-violeta-claro pt-3">
      <nav class="flex flex-col gap-1">
        {navItems.map(item => (
          <a href={item.href} class="px-3 py-2 text-sm font-medium text-epoca-marron-medio hover:text-epoca-marron hover:bg-epoca-crema rounded-lg transition-colors">
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
