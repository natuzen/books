---
interface Props {
  titulo: string;
  autor: string;
  anio: number;
  slug: string;
  tropos?: string[];
  intensidad?: number;
  portada?: string;
  categoria?: string;
  isbn?: string;
}

const { titulo, autor, anio, slug, tropos = [], intensidad = 3, portada, categoria, isbn } = Astro.props;
const hearts = '♥'.repeat(intensidad) + '♡'.repeat(5 - intensidad);
---

<article class="card-epoca group">
  <a href={`/libro/${slug}`} class="block">
    <div class="aspect-[2/3] bg-epoca-violeta-claro rounded-lg mb-3 overflow-hidden relative">
      {portada ? (
        <img
          src={portada}
          alt={`Portada de ${titulo}`}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          width="200"
          height="300"
          data-isbn={isbn}
          data-titulo={titulo}
          data-autor={autor}
          onerror="this.onerror=null;window.__coverFallback&&window.__coverFallback(this)"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          <span class="text-4xl">📚</span>
        </div>
      )}
    </div>
    <h3 class="font-playfair text-base font-semibold text-epoca-marron group-hover:text-epoca-rosa transition-colors line-clamp-2">{titulo}</h3>
    <p class="text-sm text-epoca-marron-medio mt-1">{autor} · {anio}</p>
    <p class="text-xs text-epoca-rosa mt-1 tracking-wider">{hearts}</p>
    {tropos.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-2">
        {tropos.slice(0, 2).map(tropo => (
          <span class="text-xs bg-epoca-violeta-claro text-epoca-marron px-2 py-0.5 rounded-full">{tropo}</span>
        ))}
      </div>
    )}
  </a>
</article>

<script>
  // Fallback de portada: si Open Library falla, intentar Google Books.
  // Se define una sola vez aunque haya múltiples BookCards en la página.
  if (!window.__coverFallback) {
    (window as unknown as Record<string, unknown>).__coverFallback = async (img: HTMLImageElement) => {
      const isbn = img.dataset.isbn ?? '';
      const titulo = img.dataset.titulo ?? '';
      const autor = img.dataset.autor ?? '';

      // 1. Intentar Google Books por ISBN
      if (isbn) {
        try {
          const res = await fetch(
            `https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}&maxResults=1`
          );
          const data = (await res.json()) as { items?: Array<{ volumeInfo?: { imageLinks?: { thumbnail?: string } } }> };
          const thumb = data.items?.[0]?.volumeInfo?.imageLinks?.thumbnail;
          if (thumb) { img.src = thumb.replace('http://', 'https://'); return; }
        } catch { /* continuar con el siguiente fallback */ }
      }

      // 2. Intentar Google Books por título/autor
      if (titulo) {
        try {
          let q = `intitle:${encodeURIComponent(titulo)}`;
          if (autor) q += `+inauthor:${encodeURIComponent(autor)}`;
          const res = await fetch(
            `https://www.googleapis.com/books/v1/volumes?q=${q}&maxResults=1`
          );
          const data = (await res.json()) as { items?: Array<{ volumeInfo?: { imageLinks?: { thumbnail?: string } } }> };
          const thumb = data.items?.[0]?.volumeInfo?.imageLinks?.thumbnail;
          if (thumb) { img.src = thumb.replace('http://', 'https://'); return; }
        } catch { /* continuar con el placeholder */ }
      }

      // 3. Mostrar placeholder emoji
      img.style.display = 'none';
      const parent = img.parentElement;
      if (parent) {
        const placeholder = document.createElement('div');
        placeholder.className = 'w-full h-full flex items-center justify-center';
        placeholder.innerHTML = '<span class="text-4xl">📚</span>';
        parent.appendChild(placeholder);
      }
    };
  }
</script>
